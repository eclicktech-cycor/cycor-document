flowchart TD
  subgraph u["用户层"]
    A[用户登录] --> B{是否有账号}
    B -->|否| B1[申请账号 / 自动注册]
    B -->|是| C{是否有项目权限}
  end

  subgraph p["项目层"]
    C -->|否| C1[申请加入项目]
    C -->|是| D{是否已有项目}
    D -->|否| D1[创建项目]
    D -->|是| E[进入项目]
  end

  subgraph x["部署与访问"]
    E --> F{是否需要部署服务}
    F -->|否| Z[结束]
    F -->|是| G[创建服务]
    G --> H{选择暴露方式}
    H -->|内部访问| H1[ClusterIP / 内网 Service]
    H -->|外部访问| H2{是否需要域名}
    H2 -->|否| H3[NodePort / LB IP]
    H2 -->|是| H4[Ingress + 域名解析]
    H1 --> END[服务可访问]
    H3 --> END
    H4 --> END
  end
